// ========== RENDER ==========

function renderWeeks(weeks, containerId, phase) {
  const container = document.getElementById(containerId);
  container.innerHTML = '';

  weeks.forEach((week, wi) => {
    const weekId = `${phase}-w${wi}`;
    const totalTasks = week.days.flat().length;

    const accordion = document.createElement('div');
    accordion.className = `week-accordion ${phase}-week`;
    accordion.id = weekId;

    const completedTasks = countWeekDone(weekId, totalTasks);
    const pct = totalTasks > 0 ? Math.round(completedTasks / totalTasks * 100) : 0;

    accordion.innerHTML = `
      <div class="week-header" onclick="toggleWeek('${weekId}')">
        <div class="week-num">S${wi + 1 + (phase === 'b2' ? 12 : 0)}</div>
        <div class="week-title-wrap">
          <div class="week-title">${week.title}</div>
          <div class="week-subtitle">${week.subtitle}</div>
        </div>
        <div class="week-progress-mini">
          <div class="week-prog-bar"><div class="week-prog-fill" id="wpf-${weekId}" style="width:${pct}%"></div></div>
          <span id="wpc-${weekId}">${completedTasks}/${totalTasks}</span>
        </div>
        <span class="chevron">▾</span>
      </div>
      <div class="week-body">
        <div class="day-grid" id="dg-${weekId}"></div>
        <div class="legend">
          <div class="legend-item"><div class="legend-dot" style="background:var(--teal)"></div> Speaking</div>
          <div class="legend-item"><div class="legend-dot" style="background:var(--gold)"></div> Writing</div>
          <div class="legend-item"><div class="legend-dot" style="background:#7b3fa0"></div> Listening</div>
          <div class="legend-item"><div class="legend-dot" style="background:#c94a4a"></div> Vocabulaire</div>
        </div>
      </div>
    `;
    container.appendChild(accordion);

    // Fill days
    const grid = accordion.querySelector(`#dg-${weekId}`);
    week.days.forEach((dayTasks, di) => {
      const col = document.createElement('div');
      col.className = 'day-col';
      col.innerHTML = `<div class="day-label">${DAYS[di]}</div>`;
      dayTasks.forEach((task, ti) => {
        const taskId = `${weekId}-d${di}-t${ti}`;
        const isDone = localStorage.getItem(taskId) === '1';
        const tagMap = {speak:'SPEAKING',write:'WRITING',listen:'LISTENING',vocab:'VOCAB'};
        const colorMap = {speak:'tag-speak',write:'tag-write',listen:'tag-listen',vocab:'tag-vocab'};
        const checkColorMap = {speak:'speak-task',write:'write-task',listen:'listen-task',vocab:'vocab-task'};

        const item = document.createElement('div');
        item.className = `task-item ${checkColorMap[task.type]}${isDone?' done':''}`;
        item.dataset.id = taskId;
        item.onclick = () => toggleTask(taskId, weekId, totalTasks);
        item.innerHTML = `
          <div class="task-check">${isDone ? '✓' : ''}</div>
          <div class="task-text">
            ${task.text}
            ${task.link ? `<a href="${task.link}" target="_blank" onclick="e=event;e.stopPropagation()">↗ Ouvrir le lien</a>` : ''}
          </div>
          <span class="task-tag ${colorMap[task.type]}">${tagMap[task.type]}</span>
        `;
        col.appendChild(item);
      });
      grid.appendChild(col);
    });
  });
}

function countWeekDone(weekId, totalTasks) {
  let count = 0;
  // Estimate by scanning localStorage
  for (let i = 0; i < localStorage.length; i++) {
    const key = localStorage.key(i);
    if (key && key.startsWith(weekId + '-') && localStorage.getItem(key) === '1') count++;
  }
  return count;
}

function toggleTask(taskId, weekId, totalTasks) {
  const item = document.querySelector(`[data-id="${taskId}"]`);
  const done = localStorage.getItem(taskId) === '1';
  if (done) {
    localStorage.removeItem(taskId);
    item.classList.remove('done');
    item.querySelector('.task-check').textContent = '';
  } else {
    localStorage.setItem(taskId, '1');
    item.classList.add('done');
    item.querySelector('.task-check').textContent = '✓';
  }
  updateWeekProgress(weekId, totalTasks);
  updateGlobalProgress();
}

function updateWeekProgress(weekId, totalTasks) {
  const done = countWeekDone(weekId, totalTasks);
  const pct = totalTasks > 0 ? Math.round(done / totalTasks * 100) : 0;
  const fill = document.getElementById(`wpf-${weekId}`);
  const count = document.getElementById(`wpc-${weekId}`);
  if (fill) fill.style.width = pct + '%';
  if (count) count.textContent = `${done}/${totalTasks}`;
}

function updateGlobalProgress() {
  let total = 0;
  let done = 0;
  b1Weeks.forEach((w, wi) => {
    const weekId = `b1-w${wi}`;
    const t = w.days.flat().length;
    total += t;
    done += countWeekDone(weekId, t);
  });
  b2Weeks.forEach((w, wi) => {
    const weekId = `b2-w${wi}`;
    const t = w.days.flat().length;
    total += t;
    done += countWeekDone(weekId, t);
  });
  const pct = total > 0 ? Math.round(done / total * 100) : 0;
  document.getElementById('globalBar').style.width = pct + '%';
  document.getElementById('globalCount').textContent = `${done} / ${total} tâches (${pct}%)`;
}

function toggleWeek(weekId) {
  const el = document.getElementById(weekId);
  el.classList.toggle('open');
}

function showPhase(phase) {
  document.getElementById('phase-b1').classList.remove('visible');
  document.getElementById('phase-b2').classList.remove('visible');

  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active','b1','b2','c1'));

  if (phase === 'all') {
    document.getElementById('phase-b1').classList.add('visible');
    document.getElementById('phase-b2').classList.add('visible');
    document.getElementById('nav-all').classList.add('active');
  } else if (phase === 'b1') {
    document.getElementById('phase-b1').classList.add('visible');
    document.getElementById('nav-b1').classList.add('active', 'b1');
  } else {
    document.getElementById('phase-b2').classList.add('visible');
    document.getElementById('nav-b2').classList.add('active', 'b2');
  }
}

function resetAll() {
  if (!confirm('Réinitialiser toute la progression ? Cette action est irréversible.')) return;
  localStorage.clear();
  // Rebuild
  renderWeeks(b1Weeks, 'b1-weeks', 'b1');
  renderWeeks(b2Weeks, 'b2-weeks', 'b2');
  updateGlobalProgress();
}

// Fix link clicks inside tasks
document.addEventListener('click', function(e) {
  if (e.target.tagName === 'A') e.stopPropagation();
});

// ========== INIT ==========
renderWeeks(b1Weeks, 'b1-weeks', 'b1');
renderWeeks(b2Weeks, 'b2-weeks', 'b2');
updateGlobalProgress();

// Refresh week progress bars on load
b1Weeks.forEach((w, wi) => updateWeekProgress(`b1-w${wi}`, w.days.flat().length));
b2Weeks.forEach((w, wi) => updateWeekProgress(`b2-w${wi}`, w.days.flat().length));
</script>
